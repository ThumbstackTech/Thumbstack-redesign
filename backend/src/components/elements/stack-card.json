{
  "collectionName": "components_elements_stack_cards",
  "info": {
    "displayName": "Stack Card",
    "icon": "list",
    "description": "An individual card inside the 'From The Stack' carousel"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "allowedTypes": [
        "images"
      ],
      "type": "media",
      "multiple": false,
      "required": true
    },
    "logo": {
      "allowedTypes": [
        "images"
      ],
      "type": "media",
      "multiple": false,
      "required": true
    },
    "tag": {
      "type": "enumeration",
      "enum": [
        "Blog",
        "Article",
        "Case Study",
        "News",
        "Tutorial"
      ],
      "required": true
    },
    "news_detailed": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::news-detailed.news-detailed"
    },
    "case_study": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::case-study.case-study"
    },
    "link": {
      "type": "string",
      "description": "Optional fallback URL if no relation is linked above"
    }
  }
}

