{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study",
    "description": "Deep dive into a project using premium editorial template"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "clientName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "clientName"
    },
    "heading": {
      "type": "string"
    },
    "tagline": {
      "type": "string"
    },
    "mainImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project",
      "inversedBy": "case_study"
    },
    "subtitle": {
      "type": "text"
    },
    "readTime": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "challengeText": {
      "type": "text"
    },
    "challengeImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "approachText": {
      "type": "text"
    },
    "approachBrandText": {
      "type": "string"
    },
    "approachPrinciples": {
      "type": "component",
      "repeatable": true,
      "component": "elements.feature-item"
    },
    "quote": {
      "type": "text"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "elements.feature-item"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "projectUrl": {
      "type": "string"
    },
    "accentColor": {
      "type": "string"
    },
    "backgroundColor": {
      "type": "string"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "shared.about-hero",
        "shared.best-fit",
        "shared.build-your-stack",
        "shared.capabilities-features",
        "shared.capabilities-hero-detail",
        "shared.capabilities-hero",
        "shared.capabilities-listing",
        "shared.cta-section",
        "shared.faq-section",
        "shared.footer",
        "shared.hero-work",
        "shared.hero",
        "shared.how-we-work",
        "shared.info",
        "shared.interactive-list",
        "shared.lets-talk",
        "shared.news-and-insights-grid",
        "shared.news-hero",
        "shared.partner-brands",
        "shared.principles",
        "shared.product-driven",
        "shared.projects-section",
        "shared.service-hero",
        "shared.sidebar",
        "shared.stack-item",
        "shared.team-section",
        "shared.what-we-build",
        "shared.work-interactive-list",
        "shared.work-item",
        "shared.service-hero-detail",
        "shared.service-info",
        "shared.service-list"
      ]
    }  
  }
}
