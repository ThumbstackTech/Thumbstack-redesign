{
  "kind": "collectionType",
  "collectionName": "news_detaileds",
  "info": {
    "singularName": "news-detailed",
    "pluralName": "news-detaileds",
    "displayName": "News Detailed",
    "description": "News & Insights articles/details for the grid and detail pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Project Launches",
        "Inside Thumbstack",
        "Perspectives"
      ],
      "default": "Inside Thumbstack"
    },
    "tag": {
      "type": "string",
      "default": "Article"
    },
    "ctaText": {
      "type": "string",
      "default": "Read Article"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "blocks"
    },
    "readTime": {
      "type": "string",
      "default": "5 min read"
    },
    "date": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "visual": {
      "type": "enumeration",
      "enum": [
        "red-design",
        "photo-logo",
        "purple-clarity",
        "blue-speed",
        "green-strategy",
        "plain-photo"
      ],
      "default": "photo-logo"
    },
    "bgColor": {
      "type": "string"
    },
    "galleryImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "accentColor": {
      "type": "string",
      "default": "#3145DD"
    }
  }
}
